meta {
  name: POST /v1/token/refresh
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v1/token/refresh
  body: json
  auth: none
}

# Overrides folder default — refresh uses the refresh_token in the body,
# not an Authorization header.

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}
