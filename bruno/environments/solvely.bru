vars {
  baseUrl: https://bass.solvely.pl
  wsBaseUrl: wss://bass.solvely.pl
  appId: bass-demo

  oidcAuthorizationUrl: https://auth.solvely.pl/realms/solvely/protocol/openid-connect/auth
  oidcTokenUrl: https://auth.solvely.pl/realms/solvely/protocol/openid-connect/token
  oidcClientId: bass
  ~oidcClientSecret:
  oidcCallbackUrl: http://localhost:3000/callback
  oidcAdminScope: openid bass.admin
  oidcUserScope: openid bass.sync

  ~syncToken:
  ~refreshToken:
  deviceId:
}

# Keycloak setup (solvely realm → `bass` client):
#   Valid redirect URIs must include http://localhost:3000/callback
#   so Bruno's OAuth2 flow can capture the auth code.
#
# `~`-prefixed vars are Bruno secrets — set their VALUES in Bruno's env
# editor UI; they're stored in a local-only file, not the .bru file.
